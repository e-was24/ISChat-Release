{
    "experimentalServices": {
        "frontend": {
            "root": "frontend",
            "routePrefix": "/",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "routePrefix": "/_/backend",
            "entrypoint": "main.go"
    },
    "rewrites": [
        { "source": "/_/backend/:path*", "destination": "/_/backend/:path*" },
        { "source": "/(.*)", "destination": "/index.html" }
    ]
}
